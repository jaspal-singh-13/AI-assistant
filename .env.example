# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
HUGGINGFACE_TOKEN=

# ── Langfuse (cost + latency tracking) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# ── LangSmith (trace storage + eval dataset) ──────────────────────────────────
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# ── Modal GPU deployment (optional) ───────────────────────────────────────────
# MODAL_TOKEN_ID=
