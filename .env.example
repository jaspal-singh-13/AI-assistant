# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
HF_TOKEN=

# ── Models (one line per model, no code changes needed to add/swap) ───────────
# Format: MODELS_<key>=<model_id>|<label>|<type>   (type = frontier or oss)
MODELS_claude-haiku=claude-haiku-4-5-20251001|Claude Haiku|frontier
MODELS_qwen-7b=Qwen/Qwen2.5-7B-Instruct|Qwen 2.5 7B|oss
DEFAULT_MODEL_KEY=claude-haiku

# ── Langfuse (cost + latency tracking) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# ── LangSmith (trace storage + eval dataset) ──────────────────────────────────
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# ── Modal GPU deployment (optional) ───────────────────────────────────────────
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=...


DEEPEVAL_JUDGE_MODEL=claude-haiku-4-5-20251001

# ── OSS model server ──────────────────────────────────────────────────────────
# Option A — Modal (recommended): deploy once, get a public URL
#   modal deploy serve/modal_server.py
#   → paste the printed URL below
# Option B — local GPU: python serve/model_server.py  (then use http://localhost:8000/v1)
# Leave blank to fall back to local CPU inference (slow).
OSS_SERVE_URL=
OSS_QUANT=4bit          # only used by local server; 4bit | 8bit | 16bit
OSS_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct   # HuggingFace repo; change to swap the model
OSS_HOST=0.0.0.0        # bind host for local GPU server
OSS_PORT=8000           # bind port for local GPU server

# ── Presidio PII service (Modal) ──────────────────────────────────────────────
# Deploy: modal deploy serve/presidio_modal.py
# Leave blank to fall back to local regex PII detection.
PRESIDIO_SERVE_URL=

# ── NeMo Guardrails service (Modal) ───────────────────────────────────────────
# Deploy: modal deploy serve/nemo_modal.py
# Leave blank to skip NeMo declarative rails (other guardrail stages still run).
NEMO_SERVE_URL=

# ── Modal credentials ─────────────────────────────────────────────────────────
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=