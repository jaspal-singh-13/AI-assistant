# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
HF_TOKEN=

# ── Models (one line per model, no code changes needed to add/swap) ───────────
# Format: MODELS_<key>=<model_id>|<label>|<type>   (type = frontier or oss)
MODELS_claude-haiku=claude-haiku-4-5-20251001|Claude Haiku|frontier
MODELS_llama-1b=meta-llama/Llama-3.2-1B-Instruct|Llama 3.2 1B|oss
DEFAULT_MODEL_KEY=claude-haiku

# ── Langfuse (cost + latency tracking) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# ── LangSmith (trace storage + eval dataset) ──────────────────────────────────
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# ── Modal GPU deployment (optional) ───────────────────────────────────────────
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=...
